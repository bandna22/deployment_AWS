# Lambda Environment Variables
# Supports dotenv KEY=VALUE format (lines starting with # are comments).
# Alternatively, save this file as JSON or YAML – the tool auto-detects the format.

APP_ENV=production
DB_HOST=my-db.cluster.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=appdb
DB_USER=admin
DB_PASSWORD=supersecretpassword
LOG_LEVEL=INFO
FEATURE_FLAG_NEW_UI=true
MAX_CONNECTIONS=20